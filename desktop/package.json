{
  "name": "ramppy",
  "version": "1.0.0",
  "description": "Ramppy — Plataforma de treinamento de vendas com IA",
  "main": "main.js",
  "scripts": {
    "postinstall": "node patch-electron-cli.js",
    "start": "electron .",
    "prebuild:win": "node scripts/fetch-vcredist.js",
    "build:win": "electron-builder --win",
    "prebuild:mac": "bash scripts/fetch-blackhole.sh",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.ramppy.app",
    "productName": "Ramppy",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "whatsapp-preload.js",
      "whatsapp-scraper.js",
      "audio-devices.js",
      "bubble.html",
      "bubble.css",
      "bubble.js",
      "recording.html",
      "recording.css",
      "recording.js",
      "notification-toast.html",
      "preload-notification.js",
      "copilot.html",
      "copilot.css",
      "copilot.js",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": true
    },
    "afterPack": "./scripts/sign-mac.js",
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "identity": null,
      "extraResources": [
        {
          "from": "drivers/BlackHole2ch.driver",
          "to": "drivers/BlackHole2ch.driver"
        }
      ]
    },
    "dmg": {
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 190
        },
        {
          "x": 400,
          "y": 190,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "icon": "assets/icon.icns",
      "iconSize": 80
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Ramppy",
      "artifactName": "Ramppy.${ext}",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^25.0.0",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "macos-audio-devices": "^1.4.0"
  }
}
